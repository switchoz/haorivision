# ============================================================================
# HAORI VISION — Environment Variables Template (P21)
# ============================================================================
#
# This is a template file showing all required environment variables.
# Copy this file to backend/.env and fill in your actual values.
#
# IMPORTANT: Never commit .env files to git!
# The actual .env file contains secrets and should be in .gitignore.
#
# Usage:
#   cp configs/env.template backend/.env
#   # Then edit backend/.env with your actual values
#
# ============================================================================

# ----------------------------------------------------------------------------
# Backend Server Configuration
# ----------------------------------------------------------------------------

# Server port (default: 5000, but using 3010 for HAORI VISION)
PORT=3010

# Environment mode (development | production | test)
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------

# MongoDB connection string
# Format: mongodb://localhost:27017/database_name
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/haorivision

# ----------------------------------------------------------------------------
# Frontend URL
# ----------------------------------------------------------------------------

# Frontend application URL (for CORS and redirects)
CLIENT_URL=http://localhost:3012

# ----------------------------------------------------------------------------
# AI / Anthropic API
# ----------------------------------------------------------------------------

# Anthropic Claude API key
# Get yours at: https://console.anthropic.com/
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------------------------
# Email Configuration (SMTP)
# ----------------------------------------------------------------------------

# SMTP server hostname
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
EMAIL_PORT=587

# SMTP username (usually your email address)
EMAIL_USER=your_email@example.com

# SMTP password or app-specific password
EMAIL_PASSWORD=your_email_password_here

# "From" address for outgoing emails
EMAIL_FROM=noreply@haorivision.com

# Admin email for notifications
ADMIN_EMAIL=admin@haorivision.com

# ----------------------------------------------------------------------------
# Payment Processing (Stripe)
# ----------------------------------------------------------------------------

# Stripe secret key (starts with sk_test_ or sk_live_)
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe publishable key (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Frontend (Vite)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ----------------------------------------------------------------------------
# Security / Authentication
# ----------------------------------------------------------------------------

# JWT secret for token signing (generate a random string)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here_change_this_to_random_string

# Session secret for express-session (generate a random string)
# Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here_change_this_to_random_string

# ----------------------------------------------------------------------------
# Optional: Additional Services
# ----------------------------------------------------------------------------

# Redis connection string (if using Redis for sessions/cache)
# REDIS_URL=redis://localhost:6379

# AWS S3 credentials (if using S3 for file storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-north-1
# AWS_S3_BUCKET=haorivision-media

# Cloudinary credentials (if using Cloudinary for images)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Sentry DSN (if using Sentry for error tracking)
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Google Analytics / Tag Manager
# GA_TRACKING_ID=UA-XXXXXXXXX-X
# GTM_ID=GTM-XXXXXXX

# ----------------------------------------------------------------------------
# Development / Testing
# ----------------------------------------------------------------------------

# Debug mode (true | false)
# DEBUG=true

# Log level (error | warn | info | debug)
# LOG_LEVEL=debug

# Disable rate limiting in development (true | false)
# DISABLE_RATE_LIMIT=true

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. NEVER commit this file with real values to git
# 2. Use strong, randomly generated secrets for JWT_SECRET and SESSION_SECRET
# 3. In production, use environment-specific values (not development keys)
# 4. Rotate secrets regularly (at least every 90 days)
# 5. Use different keys for development, staging, and production
# 6. Store production secrets in secure vault (AWS Secrets Manager, etc.)
#
# ============================================================================

# ============================================================================
# QUICK SETUP CHECKLIST
# ============================================================================
#
# [ ] Copy this file to backend/.env
# [ ] Replace all "your_*_here" placeholders with actual values
# [ ] Generate random secrets for JWT_SECRET and SESSION_SECRET
# [ ] Verify .env is listed in .gitignore
# [ ] Test that application starts successfully
# [ ] Run: npm run security:secret_scan to verify no secrets in git
#
# ============================================================================

# ----------------------------------------------------------------------------
# Reliability Kit (P15)
# ----------------------------------------------------------------------------

# Enable Reliability Kit features (ErrorBoundary, Logging)
REACT_APP_RELIABILITY_KIT=1

# Logging level (debug, info, warn, error)
REACT_APP_LOG_LEVEL=info

# Remote logging endpoint (optional)
REACT_APP_REMOTE_LOGGING=0
REACT_APP_LOG_ENDPOINT=/api/logs

# ----------------------------------------------------------------------------
# Performance Features
# ----------------------------------------------------------------------------

# Enable preloads and critical CSS
REACT_APP_PERF_PRELOADS=1
