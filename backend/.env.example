PORT=3010
NODE_ENV=production
CLIENT_URL=http://localhost:3012
MONGODB_URI=mongodb://127.0.0.1:27017/haorivision

STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_CURRENCY=rub
STRIPE_WEBHOOK_SECRET=whsec_replace

JWT_SECRET=replace_me
SESSION_SECRET=replace_me

EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=no-reply@example.com
EMAIL_PASSWORD=app_password
EMAIL_FROM="HaoriVision <no-reply@example.com>"

ANTHROPIC_API_KEY=sk-ant-replace
LOG_LEVEL=info
LOG_SAMPLE_RATE=0.1

# Feature Flags
FLAG_AI_ANALYSIS=true
FLAG_CRON_JOBS=false
FLAG_RATE_LIMIT=true

# OAuth Social Login (Russian segment)
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret
VK_CALLBACK_URL=http://localhost:3010/api/admin/auth/vk/callback

YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_CALLBACK_URL=http://localhost:3010/api/admin/auth/yandex/callback

MAILRU_CLIENT_ID=your_mailru_client_id
