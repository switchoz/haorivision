# ═══════════════════════════════════════════
# HAORI VISION — Production Environment
# ═══════════════════════════════════════════

# Server
PORT=3010
NODE_ENV=production
CLIENT_URL=https://haorivision.netlify.app

# MongoDB (MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/haorivision

# Security
JWT_SECRET=generate-random-64-char-string
SESSION_SECRET=generate-another-random-64-char-string

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_CURRENCY=rub
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Yandex Mail / Gmail App Password)
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USER=noreply@haorivision.com
EMAIL_PASSWORD=app-password-here
EMAIL_FROM="HAORI VISION <noreply@haorivision.com>"

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHANNEL_ID=@haorivision_channel
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# Anthropic AI (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OAuth (optional)
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Base URL
BASE_URL=https://haorivision.com
MINIAPP_URL=https://haorivision-api.onrender.com/miniapp/
